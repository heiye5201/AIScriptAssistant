{
  "manifest_version": 3,
  "name": "Eolink AI Script Assistant",
  "version": "4.0",
  "description": "AI assistant to help generate scripts within Eolink.",
  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/eolink-logo.png",
    "32": "icons/eolink-logo.png",
    "48": "icons/eolink-logo.png",
    "128": "icons/eolink-logo.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://space-o74jhl.w.eolink.com/*",
        "https://eolinker.lfsz.codefriend.top/*"
      ],
      "js": [
        "assets/content-script.js"
      ],
      "css": [
        "assets/content-script.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "assets/*",
        "prompts/eolink-rules.md"
      ],
      "matches": [
        "https://space-o74jhl.w.eolink.com/*",
        "https://eolinker.lfsz.codefriend.top/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
